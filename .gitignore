# ========================================
# debbpkg .gitignore
# ========================================

# 编译产物和可执行文件
debpkg
*.o
*.out
*.so
*.a
obj/

# 临时文件和备份
*.tmp
*~
.*.swp
.*.swo
*.bak
*.old

# 测试相关文件
test_*.deb
*.deb.bak
*.log

# 编辑器目录
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS 生成的文件
.DS_Store
Thumbs.db
desktop.ini

# 调试文件
*.gdb
*.dbg
*.pdb

# 编译中间目录
build/
bin/
lib/
include/*.h.gch

# Makefile 生成的
*.d
*.Po

*.deb